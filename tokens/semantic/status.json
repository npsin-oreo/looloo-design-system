{
  "$description": "Status colors — HAND-AUTHORED (Phase 4). Not regenerated by migrate.",
  "status": {
    "destructive": {
      "$type": "color",
      "$value": "{color.destructive}",
      "$description": "Alias of the live semantic token."
    },
    "success": {
      "$type": "color",
      "$value": "{color.green.700}",
      "$description": "Design sign-off 2026-07-08: green-700 (green-600 on white was 3.30:1 < AA). Not consumed yet.",
      "$extensions": {
        "looloo.status": "proposed"
      }
    },
    "success-foreground": {
      "$type": "color",
      "$value": "{color.white}",
      "$description": "Proposed. Not consumed yet.",
      "$extensions": {
        "looloo.status": "proposed"
      }
    },
    "warning": {
      "$type": "color",
      "$value": "{color.amber.500}",
      "$description": "The warning FILL. Consumed by badge (as a 10% tint).",
      "$extensions": {
        "looloo.status": "proposed"
      }
    },
    "warning-foreground": {
      "$type": "color",
      "$value": "{color.neutral.950}",
      "$description": "Text ON a solid warning fill.",
      "$extensions": {
        "looloo.status": "proposed"
      }
    },
    "warning-text": {
      "$type": "color",
      "$value": "{color.amber.700}",
      "$description": "Warning as TEXT (on a light/tinted surface). amber.500 is the fill colour and is far too light to read — 2.1:1 on white; amber.700 is 4.6:1. success and info need no such split: green.700 and blue.600 already pass as text."
    },
    "info": {
      "$type": "color",
      "$value": "{color.blue.600}",
      "$description": "Proposed. Not consumed yet.",
      "$extensions": {
        "looloo.status": "proposed"
      }
    },
    "info-foreground": {
      "$type": "color",
      "$value": "{color.white}",
      "$description": "Proposed. Not consumed yet.",
      "$extensions": {
        "looloo.status": "proposed"
      }
    },
    "success-surface": {
      "$type": "color",
      "$value": "{color.green.50}",
      "$description": "Success surface (solid tint). Dark: green.950."
    },
    "success-surface-hover": {
      "$type": "color",
      "$value": "{color.green.100}",
      "$description": "Success surface, hover. Dark: green.900."
    },
    "success-border": {
      "$type": "color",
      "$value": "{color.green.200}",
      "$description": "Success border. Dark: green.800."
    },
    "warning-surface": {
      "$type": "color",
      "$value": "{color.amber.50}",
      "$description": "Warning surface (solid tint). Dark: amber.950."
    },
    "warning-surface-hover": {
      "$type": "color",
      "$value": "{color.amber.100}",
      "$description": "Warning surface, hover. Dark: amber.900."
    },
    "warning-border": {
      "$type": "color",
      "$value": "{color.amber.200}",
      "$description": "Warning border. Dark: amber.800."
    },
    "info-surface": {
      "$type": "color",
      "$value": "{color.blue.50}",
      "$description": "Info surface (solid tint). Dark: blue.950."
    },
    "info-surface-hover": {
      "$type": "color",
      "$value": "{color.blue.100}",
      "$description": "Info surface, hover. Dark: blue.900."
    },
    "info-border": {
      "$type": "color",
      "$value": "{color.blue.200}",
      "$description": "Info border. Dark: blue.800."
    }
  }
}
