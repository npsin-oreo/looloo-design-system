{
  "$description": "Content (text/icon) roles — aliases into the semantic color layer. Hand-owned (NOT regenerated by tokens:migrate). Not consumed at runtime yet.",
  "content": {
    "default": {
      "$type": "color",
      "$value": "{color.foreground}",
      "$description": "Default readable text."
    },
    "muted": {
      "$type": "color",
      "$value": "{color.muted-foreground}",
      "$description": "Secondary text: descriptions, placeholders, captions."
    },
    "on-primary": {
      "$type": "color",
      "$value": "{color.primary-foreground}",
      "$description": "Text/icons on primary fills."
    },
    "on-card": {
      "$type": "color",
      "$value": "{color.card-foreground}"
    },
    "on-popover": {
      "$type": "color",
      "$value": "{color.popover-foreground}"
    },
    "on-sidebar": {
      "$type": "color",
      "$value": "{color.sidebar-foreground}"
    },
    "destructive": {
      "$type": "color",
      "$value": "{color.destructive}",
      "$description": "Error/destructive text and icons (components use text-destructive)."
    }
  }
}
