{
  "$description": "Captured 1:1 from components/ui/breadcrumb/breadcrumb.tsx. The separator chevron is size-3.5 — deliberately smaller than the 16px icon default.",
  "breadcrumb": {
    "gap": {
      "$type": "dimension",
      "$value": "{space.1-5}",
      "$description": "Gap between crumbs in the list.",
      "$extensions": {
        "looloo.tailwind": "gap-1.5"
      }
    },
    "itemGap": {
      "$type": "dimension",
      "$value": "{space.1}",
      "$description": "Gap inside one crumb (icon + label).",
      "$extensions": {
        "looloo.tailwind": "gap-1"
      }
    },
    "fontSize": {
      "$type": "dimension",
      "$value": "{font.size.sm}",
      "$extensions": {
        "looloo.tailwind": "text-sm"
      }
    },
    "pageFontWeight": {
      "$type": "fontWeight",
      "$value": "{font.weight.normal}",
      "$description": "The current page is not bolded — it is distinguished by color only.",
      "$extensions": {
        "looloo.tailwind": "font-normal"
      }
    },
    "separatorIconSize": {
      "$type": "dimension",
      "$value": "{size.14}",
      "$extensions": {
        "looloo.tailwind": "[&>svg]:size-3.5",
        "looloo.legacy": "0.875rem"
      }
    },
    "ellipsis": {
      "size": {
        "$type": "dimension",
        "$value": "{size.20}",
        "$description": "size-5 = 20px — below the size.control scale.",
        "$extensions": {
          "looloo.tailwind": "size-5",
          "looloo.legacy": "1.25rem"
        }
      },
      "iconSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$extensions": {
          "looloo.tailwind": "[&>svg]:size-4",
          "looloo.legacy": "1rem"
        }
      }
    }
  }
}
