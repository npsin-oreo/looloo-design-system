{
  "$description": "Captured 1:1 from components/ui/chat/chat.tsx. Bubbles are rounded-2xl, except on the side facing an adjacent bubble in the same group, where the two corners tighten to rounded-md — that is what makes a run of messages read as one block.",
  "chat": {
    "list": {
      "padding": {
        "$type": "dimension",
        "$value": "{space.4}",
        "$extensions": {
          "looloo.tailwind": "p-4"
        }
      },
      "emptyFontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      }
    },
    "bubble": {
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.2xl}",
        "$extensions": {
          "looloo.tailwind": "rounded-2xl"
        }
      },
      "groupedRadius": {
        "$type": "dimension",
        "$value": "{radius.ui.md}",
        "$description": "The corners facing the neighbouring bubble in a group (rounded-tl-md / -bl-md, mirrored for the user side).",
        "$extensions": {
          "looloo.tailwind": "rounded-bl-md"
        }
      },
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.3}",
        "$extensions": {
          "looloo.tailwind": "px-3"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "py-2"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      },
      "maxWidth": {
        "$type": "dimension",
        "$value": "65ch",
        "$description": "max-w-prose — a ch-based measure, not a px token.",
        "$extensions": {
          "looloo.tailwind": "max-w-prose"
        }
      }
    },
    "message": {
      "gap": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$description": "Between the bubble and its name/meta lines.",
        "$extensions": {
          "looloo.tailwind": "gap-1"
        }
      },
      "rowGap": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "gap-2"
        }
      },
      "avatarGap": {
        "$type": "dimension",
        "$value": "{space.3}",
        "$extensions": {
          "looloo.tailwind": "gap-3"
        }
      },
      "nameFontSize": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "nameFontWeight": {
        "$type": "fontWeight",
        "$value": "{font.weight.medium}",
        "$extensions": {
          "looloo.tailwind": "font-medium"
        }
      },
      "metaGap": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "gap-2"
        }
      },
      "metaFontSize": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      }
    },
    "composer": {
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.2xl}",
        "$extensions": {
          "looloo.tailwind": "rounded-2xl"
        }
      },
      "padding": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "p-2"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "gap-2"
        }
      },
      "borderWidth": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$extensions": {
          "looloo.tailwind": "border"
        }
      },
      "shadow": {
        "$type": "shadow",
        "$value": "{shadow.xs}",
        "$extensions": {
          "looloo.tailwind": "shadow-xs"
        }
      },
      "focusRingWidth": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$description": "focus-within:ring-1 — a hairline ring, not the 3px form ring.",
        "$extensions": {
          "looloo.tailwind": "focus-within:ring-1"
        }
      },
      "inputPaddingX": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "px-1"
        }
      },
      "inputPaddingY": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "py-1.5"
        }
      },
      "inputFontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      }
    },
    "action": {
      "sizeSm": {
        "$type": "dimension",
        "$value": "{size.control.sm}",
        "$extensions": {
          "looloo.tailwind": "size-7"
        }
      },
      "size": {
        "$type": "dimension",
        "$value": "{size.control.md}",
        "$extensions": {
          "looloo.tailwind": "size-8"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.full}",
        "$extensions": {
          "looloo.tailwind": "rounded-full"
        }
      },
      "iconSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$extensions": {
          "looloo.tailwind": "size-4",
          "looloo.legacy": "1rem"
        }
      },
      "stopIconSize": {
        "$type": "dimension",
        "$value": "{size.12}",
        "$extensions": {
          "looloo.tailwind": "size-3",
          "looloo.legacy": "0.75rem"
        }
      },
      "focusRingWidth": {
        "$type": "dimension",
        "$value": "{border.width.2}",
        "$extensions": {
          "looloo.tailwind": "focus-visible:ring-2"
        }
      },
      "disabledOpacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "disabled:opacity-50"
        }
      }
    },
    "divider": {
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "px-2"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "py-1"
        }
      }
    }
  }
}
