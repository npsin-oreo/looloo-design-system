{
  "$description": "Captured 1:1 from components/ui/empty/empty.tsx. A dashed-border placeholder panel — note the border is dashed and the container has no background of its own.",
  "empty": {
    "padding": {
      "$type": "dimension",
      "$value": "{space.6}",
      "$extensions": {
        "looloo.tailwind": "p-6"
      }
    },
    "gap": {
      "$type": "dimension",
      "$value": "{space.4}",
      "$extensions": {
        "looloo.tailwind": "gap-4"
      }
    },
    "radius": {
      "$type": "dimension",
      "$value": "{radius.ui.xl}",
      "$extensions": {
        "looloo.tailwind": "rounded-xl"
      }
    },
    "borderWidth": {
      "$type": "dimension",
      "$value": "{border.width.default}",
      "$description": "border-dashed — dashed, not solid.",
      "$extensions": {
        "looloo.tailwind": "border-dashed"
      }
    },
    "maxWidth": {
      "$type": "dimension",
      "$value": "{space.96}",
      "$description": "max-w-sm = 384px, on both the header and the content blocks.",
      "$extensions": {
        "looloo.tailwind": "max-w-sm"
      }
    },
    "header": {
      "gap": {
        "$type": "dimension",
        "$value": "{space.2-5}",
        "$extensions": {
          "looloo.tailwind": "gap-2.5"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      }
    },
    "media": {
      "size": {
        "$type": "dimension",
        "$value": "{size.control.md}",
        "$extensions": {
          "looloo.tailwind": "size-8"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.lg}",
        "$extensions": {
          "looloo.tailwind": "rounded-lg"
        }
      },
      "iconSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$extensions": {
          "looloo.tailwind": "[&_svg]:size-4",
          "looloo.legacy": "1rem"
        }
      }
    },
    "title": {
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      },
      "fontWeight": {
        "$type": "fontWeight",
        "$value": "{font.weight.medium}",
        "$extensions": {
          "looloo.tailwind": "font-medium"
        }
      },
      "tracking": {
        "$type": "dimension",
        "$value": "{font.tracking.tight}",
        "$extensions": {
          "looloo.tailwind": "tracking-tight"
        }
      }
    },
    "description": {
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm/relaxed"
        }
      },
      "lineHeight": {
        "$type": "number",
        "$value": 1.625,
        "$description": "text-sm/relaxed — leading-relaxed, no leading token matches.",
        "$extensions": {
          "looloo.tailwind": "text-sm/relaxed"
        }
      }
    },
    "content": {
      "gap": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "gap-2"
        }
      }
    }
  }
}
