{
  "$description": "Captured 1:1 from the cva in components/ui/alert/alert.tsx (Alert, AlertTitle, AlertDescription, AlertAction). Variants default/destructive share every dimension — only colors differ.",
  "alert": {
    "radius": {
      "$type": "dimension",
      "$value": "{radius.ui.lg}",
      "$extensions": {
        "looloo.tailwind": "rounded-lg"
      }
    },
    "borderWidth": {
      "$type": "dimension",
      "$value": "{border.width.default}",
      "$extensions": {
        "looloo.tailwind": "border"
      }
    },
    "paddingX": {
      "$type": "dimension",
      "$value": "{space.2-5}",
      "$extensions": {
        "looloo.tailwind": "px-2.5"
      }
    },
    "paddingY": {
      "$type": "dimension",
      "$value": "{space.2}",
      "$extensions": {
        "looloo.tailwind": "py-2"
      }
    },
    "gap": {
      "$type": "dimension",
      "$value": "{space.0-5}",
      "$description": "Row gap between title and description.",
      "$extensions": {
        "looloo.tailwind": "gap-0.5"
      }
    },
    "iconGap": {
      "$type": "dimension",
      "$value": "{space.2}",
      "$description": "Column gap when the alert has a leading icon.",
      "$extensions": {
        "looloo.tailwind": "has-[>svg]:gap-x-2"
      }
    },
    "iconSize": {
      "$type": "dimension",
      "$value": "{size.16}",
      "$extensions": {
        "looloo.tailwind": "*:[svg]:size-4",
        "looloo.legacy": "1rem"
      }
    },
    "fontSize": {
      "$type": "dimension",
      "$value": "{font.size.sm}",
      "$extensions": {
        "looloo.tailwind": "text-sm"
      }
    },
    "titleFontWeight": {
      "$type": "fontWeight",
      "$value": "{font.weight.medium}",
      "$extensions": {
        "looloo.tailwind": "font-medium"
      }
    },
    "action": {
      "inset": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "top-2 right-2"
        }
      },
      "reservedWidth": {
        "$type": "dimension",
        "$value": "4.5rem",
        "$description": "Right padding reserved for the action slot (pr-18 = 72px — no space token at 18).",
        "$extensions": {
          "looloo.tailwind": "has-data-[slot=alert-action]:pr-18"
        }
      }
    },
    "background": {
      "$type": "color",
      "$value": "{color.card}",
      "$extensions": {
        "looloo.tailwind": "bg-card"
      }
    },
    "foreground": {
      "$type": "color",
      "$value": "{color.card-foreground}",
      "$extensions": {
        "looloo.tailwind": "text-card-foreground"
      }
    },
    "descriptionForeground": {
      "$type": "color",
      "$value": "{color.muted-foreground}",
      "$extensions": {
        "looloo.tailwind": "text-muted-foreground"
      }
    },
    "destructiveForeground": {
      "$type": "color",
      "$value": "{color.destructive}",
      "$extensions": {
        "looloo.tailwind": "text-destructive"
      }
    },
    "color": {
      "default-surface": {
        "$type": "color",
        "$value": "{color.card}",
        "$description": "Neutral news. No tint: if every alert is coloured, colour stops meaning anything.",
        "$extensions": {
          "looloo.tailwind": "bg-card"
        }
      },
      "default-foreground": {
        "$type": "color",
        "$value": "{color.card-foreground}",
        "$description": "Neutral title.",
        "$extensions": {
          "looloo.tailwind": "text-card-foreground"
        }
      },
      "success-surface": {
        "$type": "color",
        "$value": "color-mix(in oklch, var(--status-success) 10%, transparent)",
        "$description": "A 10% green wash. Ten percent is the ceiling: past that the panel starts to compete with the text it is supposed to be carrying, and the contrast of the body copy drops.",
        "$extensions": {
          "looloo.tailwind": "bg-(--alert-color-success-surface)"
        }
      },
      "success-border": {
        "$type": "color",
        "$value": "color-mix(in oklch, var(--status-success) 25%, transparent)",
        "$description": "The border is a stronger mix than the fill — it is what draws the box; the fill only tints it.",
        "$extensions": {
          "looloo.tailwind": "border-(--alert-color-success-border)"
        }
      },
      "success-foreground": {
        "$type": "color",
        "$value": "{status.success}",
        "$description": "green.700 — the readable step, NOT the 500 that the icon uses.",
        "$extensions": {
          "looloo.tailwind": "text-(--alert-color-success-foreground)"
        }
      },
      "warning-surface": {
        "$type": "color",
        "$value": "color-mix(in oklch, var(--status-warning) 10%, transparent)",
        "$description": "A 10% amber wash — something MIGHT go wrong.",
        "$extensions": {
          "looloo.tailwind": "bg-(--alert-color-warning-surface)"
        }
      },
      "warning-border": {
        "$type": "color",
        "$value": "color-mix(in oklch, var(--status-warning) 25%, transparent)",
        "$description": "Amber edge.",
        "$extensions": {
          "looloo.tailwind": "border-(--alert-color-warning-border)"
        }
      },
      "warning-foreground": {
        "$type": "color",
        "$value": "{status.warning-text}",
        "$description": "amber.700 — amber.500 only reaches 2.1:1 on a light tint and is unreadable as text.",
        "$extensions": {
          "looloo.tailwind": "text-(--alert-color-warning-foreground)"
        }
      },
      "info-surface": {
        "$type": "color",
        "$value": "color-mix(in oklch, var(--status-info) 10%, transparent)",
        "$description": "A 10% blue wash — context, not a problem.",
        "$extensions": {
          "looloo.tailwind": "bg-(--alert-color-info-surface)"
        }
      },
      "info-border": {
        "$type": "color",
        "$value": "color-mix(in oklch, var(--status-info) 25%, transparent)",
        "$description": "Blue edge.",
        "$extensions": {
          "looloo.tailwind": "border-(--alert-color-info-border)"
        }
      },
      "info-foreground": {
        "$type": "color",
        "$value": "{status.info}",
        "$description": "blue.700.",
        "$extensions": {
          "looloo.tailwind": "text-(--alert-color-info-foreground)"
        }
      },
      "destructive-surface": {
        "$type": "color",
        "$value": "color-mix(in oklch, var(--destructive) 10%, transparent)",
        "$description": "A 10% red wash — this already went wrong. Still only 10%: a solid red panel is the one that makes the error message hardest to read.",
        "$extensions": {
          "looloo.tailwind": "bg-(--alert-color-destructive-surface)"
        }
      },
      "destructive-border": {
        "$type": "color",
        "$value": "color-mix(in oklch, var(--destructive) 25%, transparent)",
        "$description": "Red edge.",
        "$extensions": {
          "looloo.tailwind": "border-(--alert-color-destructive-border)"
        }
      },
      "destructive-foreground": {
        "$type": "color",
        "$value": "{color.destructive}",
        "$description": "Red title.",
        "$extensions": {
          "looloo.tailwind": "text-destructive"
        }
      }
    }
  }
}
