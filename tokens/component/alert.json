{
  "$description": "Captured 1:1 from the cva in components/ui/alert/alert.tsx (Alert, AlertTitle, AlertDescription, AlertAction). Variants default/destructive share every dimension — only colors differ.",
  "alert": {
    "radius": {
      "$type": "dimension",
      "$value": "{radius.ui.lg}",
      "$extensions": {
        "looloo.tailwind": "rounded-lg"
      }
    },
    "borderWidth": {
      "$type": "dimension",
      "$value": "{border.width.default}",
      "$extensions": {
        "looloo.tailwind": "border"
      }
    },
    "paddingX": {
      "$type": "dimension",
      "$value": "{space.2-5}",
      "$extensions": {
        "looloo.tailwind": "px-2.5"
      }
    },
    "paddingY": {
      "$type": "dimension",
      "$value": "{space.2}",
      "$extensions": {
        "looloo.tailwind": "py-2"
      }
    },
    "gap": {
      "$type": "dimension",
      "$value": "{space.0-5}",
      "$description": "Row gap between title and description.",
      "$extensions": {
        "looloo.tailwind": "gap-0.5"
      }
    },
    "iconGap": {
      "$type": "dimension",
      "$value": "{space.2}",
      "$description": "Column gap when the alert has a leading icon.",
      "$extensions": {
        "looloo.tailwind": "has-[>svg]:gap-x-2"
      }
    },
    "iconSize": {
      "$type": "dimension",
      "$value": "{size.16}",
      "$extensions": {
        "looloo.tailwind": "*:[svg]:size-4",
        "looloo.legacy": "1rem"
      }
    },
    "fontSize": {
      "$type": "dimension",
      "$value": "{font.size.sm}",
      "$extensions": {
        "looloo.tailwind": "text-sm"
      }
    },
    "titleFontWeight": {
      "$type": "fontWeight",
      "$value": "{font.weight.medium}",
      "$extensions": {
        "looloo.tailwind": "font-medium"
      }
    },
    "action": {
      "inset": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "top-2 right-2"
        }
      },
      "reservedWidth": {
        "$type": "dimension",
        "$value": "4.5rem",
        "$description": "Right padding reserved for the action slot (pr-18 = 72px — no space token at 18).",
        "$extensions": {
          "looloo.tailwind": "has-data-[slot=alert-action]:pr-18"
        }
      }
    }
  }
}
