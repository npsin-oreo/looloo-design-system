{
  "$description": "Captured 1:1 from components/ui/token/token.tsx — the entity/mention pill used in agentic UI. Sizes sm/md/lg; variants default (primary) / secondary / muted. The remove button sits at 70% opacity until hover.",
  "token": {
    "height": {
      "sm": {
        "$type": "dimension",
        "$value": "{size.20}",
        "$description": "h-5 = 20px — below size.control.xs (24px).",
        "$extensions": {
          "looloo.tailwind": "h-5",
          "looloo.legacy": "1.25rem"
        }
      },
      "md": {
        "$type": "dimension",
        "$value": "{size.control.xs}",
        "$extensions": {
          "looloo.tailwind": "h-6"
        }
      },
      "lg": {
        "$type": "dimension",
        "$value": "{size.control.sm}",
        "$extensions": {
          "looloo.tailwind": "h-7"
        }
      }
    },
    "paddingX": {
      "sm": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "px-1.5"
        }
      },
      "md": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "px-2"
        }
      },
      "lg": {
        "$type": "dimension",
        "$value": "{space.2-5}",
        "$extensions": {
          "looloo.tailwind": "px-2.5"
        }
      }
    },
    "gap": {
      "sm": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "gap-1"
        }
      },
      "md": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "gap-1.5"
        }
      },
      "lg": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "gap-1.5"
        }
      }
    },
    "fontSize": {
      "sm": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "md": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "lg": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      }
    },
    "iconSize": {
      "sm": {
        "$type": "dimension",
        "$value": "{size.12}",
        "$extensions": {
          "looloo.tailwind": "[&_svg]:size-3",
          "looloo.legacy": "0.75rem"
        }
      },
      "md": {
        "$type": "dimension",
        "$value": "{size.14}",
        "$extensions": {
          "looloo.tailwind": "[&_svg]:size-3.5",
          "looloo.legacy": "0.875rem"
        }
      },
      "lg": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$extensions": {
          "looloo.tailwind": "[&_svg]:size-4",
          "looloo.legacy": "1rem"
        }
      }
    },
    "radius": {
      "$type": "dimension",
      "$value": "{radius.ui.md}",
      "$extensions": {
        "looloo.tailwind": "rounded-md"
      }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "$value": "{font.weight.medium}",
      "$extensions": {
        "looloo.tailwind": "font-medium"
      }
    },
    "disabledOpacity": {
      "$type": "number",
      "$value": "{opacity.50}",
      "$extensions": {
        "looloo.tailwind": "data-[disabled]:opacity-50"
      }
    },
    "defaultBackground": {
      "$type": "color",
      "$value": "{color.primary}",
      "$extensions": {
        "looloo.tailwind": "bg-primary"
      }
    },
    "defaultForeground": {
      "$type": "color",
      "$value": "{color.primary-foreground}",
      "$extensions": {
        "looloo.tailwind": "text-primary-foreground"
      }
    },
    "secondaryBackground": {
      "$type": "color",
      "$value": "{color.secondary}",
      "$extensions": {
        "looloo.tailwind": "bg-secondary"
      }
    },
    "secondaryForeground": {
      "$type": "color",
      "$value": "{color.secondary-foreground}",
      "$extensions": {
        "looloo.tailwind": "text-secondary-foreground"
      }
    },
    "mutedBackground": {
      "$type": "color",
      "$value": "{color.muted}",
      "$extensions": {
        "looloo.tailwind": "bg-muted"
      }
    },
    "mutedForeground": {
      "$type": "color",
      "$value": "{color.foreground}",
      "$extensions": {
        "looloo.tailwind": "text-foreground"
      }
    },
    "label": {
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.sm}",
        "$extensions": {
          "looloo.tailwind": "rounded-sm"
        }
      },
      "focusRingWidth": {
        "$type": "dimension",
        "$value": "{border.width.2}",
        "$extensions": {
          "looloo.tailwind": "focus-visible:ring-2"
        }
      }
    },
    "remove": {
      "radius": {
        "$type": "dimension",
        "$value": "{radius.full}",
        "$extensions": {
          "looloo.tailwind": "rounded-full"
        }
      },
      "inset": {
        "$type": "dimension",
        "$value": "{space.0-5}",
        "$description": "ml-0.5 with a matching -mr-0.5 so the button hugs the pill's right edge.",
        "$extensions": {
          "looloo.tailwind": "-mr-0.5 ml-0.5"
        }
      },
      "opacity": {
        "$type": "number",
        "$value": "{opacity.70}",
        "$description": "Goes to 100% on hover.",
        "$extensions": {
          "looloo.tailwind": "opacity-70 hover:opacity-100"
        }
      },
      "focusRingWidth": {
        "$type": "dimension",
        "$value": "{border.width.2}",
        "$extensions": {
          "looloo.tailwind": "focus-visible:ring-2"
        }
      }
    }
  }
}
