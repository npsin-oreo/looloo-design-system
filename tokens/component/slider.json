{
  "$description": "Captured from components/ui/slider/slider.tsx — WIRED. Added in Phase 4 to eliminate the raw bg-white on the thumb (the one palette-utility violation in the codebase). The thumb is white in BOTH modes by design (ring-bordered puck), so it references the white primitive — a semantic role would wrongly flip it in dark mode.",
  "slider": {
    "thumbSize": {
      "$type": "dimension",
      "$value": "{size.12}",
      "$extensions": {
        "looloo.tailwind": "size-3",
        "looloo.legacy": "0.75rem"
      }
    },
    "thumbBackground": {
      "$type": "color",
      "$value": "{color.white}",
      "$extensions": {
        "looloo.tailwind": "bg-white (pre-Phase-4)"
      }
    },
    "color": {
      "track": {
        "$type": "color",
        "$value": "{color.muted}",
        "$extensions": {
          "looloo.tailwind": "bg-muted"
        }
      },
      "range": {
        "$type": "color",
        "$value": "{color.primary}",
        "$description": "The filled portion of the track.",
        "$extensions": {
          "looloo.tailwind": "bg-primary"
        }
      },
      "thumb-border": {
        "$type": "color",
        "$value": "{color.primary}",
        "$extensions": {
          "looloo.tailwind": "border-primary"
        }
      },
      "focus-ring": {
        "$type": "color",
        "$value": "{color.ring}",
        "$extensions": {
          "looloo.tailwind": "focus-visible:ring-ring/50"
        }
      },
      "focus-ring-opacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "ring-ring/50"
        }
      }
    }
  }
}
