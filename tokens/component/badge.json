{
  "$description": "DRAFT — captured from components/ui/badge.tsx. Not consumed at runtime yet (Phase 4).",
  "badge": {
    "height": {
      "$type": "dimension",
      "$value": "{size.20}",
      "$extensions": {
        "looloo.tailwind": "h-5",
        "looloo.legacy": "1.25rem"
      }
    },
    "paddingX": {
      "$type": "dimension",
      "$value": "{space.2}",
      "$extensions": {
        "looloo.tailwind": "px-2"
      }
    },
    "paddingY": {
      "$type": "dimension",
      "$value": "{space.0-5}",
      "$extensions": {
        "looloo.tailwind": "py-0.5"
      }
    },
    "gap": {
      "$type": "dimension",
      "$value": "{space.1}",
      "$extensions": {
        "looloo.tailwind": "gap-1"
      }
    },
    "radius": {
      "$type": "dimension",
      "$value": "{radius.ui.4xl}",
      "$description": "rounded-4xl = calc(var(--radius) * 2.6) — pill-like.",
      "$extensions": {
        "looloo.tailwind": "rounded-4xl",
        "looloo.legacy": "1.625rem"
      }
    },
    "fontSize": {
      "$type": "dimension",
      "$value": "{font.size.xs}",
      "$extensions": {
        "looloo.tailwind": "text-xs"
      }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "$value": "{font.weight.medium}",
      "$extensions": {
        "looloo.tailwind": "font-medium"
      }
    },
    "iconSize": {
      "$type": "dimension",
      "$value": "{size.12}",
      "$extensions": {
        "looloo.tailwind": "size-3",
        "looloo.legacy": "0.75rem"
      }
    }
  }
}
