{
  "$description": "Captured 1:1 from components/ui/blockquote/blockquote.tsx. A left rule + indent; the cite line is muted and explicitly not italic.",
  "blockquote": {
    "borderWidth": {
      "$type": "dimension",
      "$value": "{border.width.2}",
      "$extensions": {
        "looloo.tailwind": "border-l-2"
      }
    },
    "paddingLeft": {
      "$type": "dimension",
      "$value": "{space.6}",
      "$extensions": {
        "looloo.tailwind": "pl-6"
      }
    },
    "blockGap": {
      "$type": "dimension",
      "$value": "{space.2}",
      "$description": "Between stacked children inside the quote.",
      "$extensions": {
        "looloo.tailwind": "[&>*+*]:mt-2"
      }
    },
    "cite": {
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      }
    }
  }
}
