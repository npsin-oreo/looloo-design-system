{
  "$description": "Captured 1:1 from components/ui/dropdown-menu/dropdown-menu.tsx. The item/label/separator/shortcut geometry is shared verbatim with context-menu and menubar; each file keeps its own copy so a component can drift without breaking the others.",
  "dropdownMenu": {
    "content": {
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.lg}",
        "$extensions": {
          "looloo.tailwind": "rounded-lg"
        }
      },
      "padding": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "p-1"
        }
      },
      "minWidth": {
        "$type": "dimension",
        "$value": "{space.32}",
        "$extensions": {
          "looloo.tailwind": "min-w-32"
        }
      },
      "ringWidth": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$description": "ring-1 ring-foreground/10 — a ring, not a border.",
        "$extensions": {
          "looloo.tailwind": "ring-1"
        }
      },
      "shadow": {
        "$type": "shadow",
        "$value": "{shadow.md}",
        "$extensions": {
          "looloo.tailwind": "shadow-md"
        }
      }
    },
    "subContent": {
      "minWidth": {
        "$type": "dimension",
        "$value": "{size.96}",
        "$description": "min-w-[96px] — literal in source, no space token at 96px.",
        "$extensions": {
          "looloo.tailwind": "min-w-[96px]",
          "looloo.legacy": "6rem"
        }
      },
      "shadow": {
        "$type": "shadow",
        "$value": "{shadow.lg}",
        "$extensions": {
          "looloo.tailwind": "shadow-lg"
        }
      }
    },
    "item": {
      "radius": {
        "$type": "dimension",
        "$value": "calc(var(--dropdown-menu-content-radius) - var(--dropdown-menu-content-padding))",
        "$description": "CONCENTRIC: --dropdown-menu-content-radius − --dropdown-menu-content-padding = 6px. A nested corner must be the outer radius MINUS the padding, or the gap at the corner is not the gap along the edge — the inner box looks either pinched or rattling around inside its container. Was picked off the radius scale by eye; now it is derived.",
        "$extensions": {
          "looloo.tailwind": "rounded-(--dropdown-menu-content-item-radius)",
          "looloo.previous": "{radius.ui.md}"
        }
      },
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "px-1.5"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "py-1"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "gap-1.5"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      },
      "iconSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$extensions": {
          "looloo.tailwind": "[&_svg]:size-4",
          "looloo.legacy": "1rem"
        }
      },
      "insetPaddingLeft": {
        "$type": "dimension",
        "$value": "{space.7}",
        "$description": "data-inset — reserves room for a leading check/radio indicator.",
        "$extensions": {
          "looloo.tailwind": "data-inset:pl-7"
        }
      },
      "indicatorPaddingRight": {
        "$type": "dimension",
        "$value": "{space.8}",
        "$description": "Checkbox/radio items park the indicator on the right.",
        "$extensions": {
          "looloo.tailwind": "pr-8"
        }
      },
      "disabledOpacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "data-disabled:opacity-50"
        }
      }
    },
    "label": {
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "px-1.5"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "py-1"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "fontWeight": {
        "$type": "fontWeight",
        "$value": "{font.weight.medium}",
        "$extensions": {
          "looloo.tailwind": "font-medium"
        }
      }
    },
    "separator": {
      "marginY": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "my-1"
        }
      },
      "bleedX": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$description": "Applied as a NEGATIVE margin (-mx-1) so the rule bleeds past the content padding.",
        "$extensions": {
          "looloo.tailwind": "-mx-1"
        }
      },
      "thickness": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$extensions": {
          "looloo.tailwind": "h-px"
        }
      }
    },
    "shortcut": {
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "tracking": {
        "$type": "dimension",
        "$value": "{font.tracking.widest}",
        "$extensions": {
          "looloo.tailwind": "tracking-widest"
        }
      }
    }
  }
}
