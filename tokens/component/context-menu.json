{
  "$description": "Captured 1:1 from components/ui/context-menu/context-menu.tsx. Same item geometry as dropdown-menu; the content min-widths differ (36 vs 32) and the sub-content carries a real border.",
  "contextMenu": {
    "content": {
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.lg}",
        "$extensions": {
          "looloo.tailwind": "rounded-lg"
        }
      },
      "padding": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "p-1"
        }
      },
      "minWidth": {
        "$type": "dimension",
        "$value": "{space.36}",
        "$extensions": {
          "looloo.tailwind": "min-w-36"
        }
      },
      "ringWidth": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$extensions": {
          "looloo.tailwind": "ring-1"
        }
      },
      "shadow": {
        "$type": "shadow",
        "$value": "{shadow.md}",
        "$extensions": {
          "looloo.tailwind": "shadow-md"
        }
      }
    },
    "subContent": {
      "minWidth": {
        "$type": "dimension",
        "$value": "{space.32}",
        "$extensions": {
          "looloo.tailwind": "min-w-32"
        }
      },
      "borderWidth": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$description": "Sub-content uses a border here, not the ring the root content uses.",
        "$extensions": {
          "looloo.tailwind": "border"
        }
      },
      "shadow": {
        "$type": "shadow",
        "$value": "{shadow.lg}",
        "$extensions": {
          "looloo.tailwind": "shadow-lg"
        }
      },
      "chevronSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$description": "The chevron on a row that opens a submenu. ml-auto — pinned right.",
        "$extensions": {
          "looloo.tailwind": "[&_svg]:size-4 ml-auto"
        }
      }
    },
    "item": {
      "radius": {
        "$type": "dimension",
        "$value": "calc(var(--context-menu-content-radius) - var(--context-menu-content-padding))",
        "$description": "CONCENTRIC: --context-menu-content-radius − --context-menu-content-padding = 6px. A nested corner must be the outer radius MINUS the padding, or the gap at the corner is not the gap along the edge — the inner box looks either pinched or rattling around inside its container. Was picked off the radius scale by eye; now it is derived.",
        "$extensions": {
          "looloo.tailwind": "rounded-(--context-menu-content-item-radius)",
          "looloo.previous": "{radius.ui.md}"
        }
      },
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "px-1.5"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "py-1"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "gap-1.5"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      },
      "iconSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$extensions": {
          "looloo.tailwind": "[&_svg]:size-4",
          "looloo.legacy": "1rem"
        }
      },
      "insetPaddingLeft": {
        "$type": "dimension",
        "$value": "{space.7}",
        "$extensions": {
          "looloo.tailwind": "data-inset:pl-7"
        }
      },
      "indicatorPaddingRight": {
        "$type": "dimension",
        "$value": "{space.8}",
        "$extensions": {
          "looloo.tailwind": "pr-8"
        }
      },
      "disabledOpacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "data-disabled:opacity-50"
        }
      },
      "indicatorInset": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$description": "The check sits on the RIGHT edge (absolute right-2) — unlike Dropdown menu, where it leads the row.",
        "$extensions": {
          "looloo.tailwind": "absolute right-2"
        }
      },
      "indicatorSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$extensions": {
          "looloo.tailwind": "size-4"
        }
      }
    },
    "label": {
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "px-1.5"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "py-1"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "fontWeight": {
        "$type": "fontWeight",
        "$value": "{font.weight.medium}",
        "$extensions": {
          "looloo.tailwind": "font-medium"
        }
      }
    },
    "separator": {
      "marginY": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "my-1"
        }
      },
      "bleedX": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$description": "Applied as a NEGATIVE margin (-mx-1).",
        "$extensions": {
          "looloo.tailwind": "-mx-1"
        }
      },
      "thickness": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$extensions": {
          "looloo.tailwind": "h-px"
        }
      }
    },
    "shortcut": {
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "tracking": {
        "$type": "dimension",
        "$value": "{font.tracking.widest}",
        "$extensions": {
          "looloo.tailwind": "tracking-widest"
        }
      }
    }
  }
}
