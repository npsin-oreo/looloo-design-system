{
  "$description": "DRAFT — captured from components/ui/tabs.tsx. Not consumed at runtime yet (Phase 4).",
  "tabs": {
    "list": {
      "height": {
        "$type": "dimension",
        "$value": "{size.control.md}",
        "$extensions": {
          "looloo.tailwind": "h-8"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.lg}",
        "$extensions": {
          "looloo.tailwind": "rounded-lg",
          "looloo.legacy": "0.625rem"
        }
      },
      "padding": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$description": "4px. FIX 2026-07-14: upstream shadcn ships p-[3px] — an arbitrary literal that lands on no step of the space scale (which goes 2 · 4 · 6 · 8). 3px cannot be expressed as a token without inventing one, so both the code and this token moved to 4px. The active tab renders 2px shorter than before; nothing else changes.",
        "$extensions": {
          "looloo.tailwind": "p-1"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.0}",
        "$description": "ZERO. The triggers sit flush; the active tab is separated by its FILL, not by a gap. A gap here would make the inactive tabs read as separate buttons.",
        "$extensions": {
          "looloo.tailwind": "— (no gap in the source)"
        }
      }
    },
    "trigger": {
      "radius": {
        "$type": "dimension",
        "$value": "calc(var(--tabs-list-radius) - var(--tabs-list-padding))",
        "$description": "CONCENTRIC: --tabs-list-radius − --tabs-list-padding = 6px. A nested corner must be the outer radius MINUS the padding, or the gap at the corner is not the gap along the edge — the inner box looks either pinched or rattling around inside its container. Was picked off the radius scale by eye; now it is derived.",
        "$extensions": {
          "looloo.tailwind": "rounded-(--tabs-list-item-radius)",
          "looloo.previous": "{radius.ui.md}"
        }
      },
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "px-1.5"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.0-5}",
        "$extensions": {
          "looloo.tailwind": "py-0.5"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      }
    },
    "indicatorThickness": {
      "$type": "dimension",
      "$value": "0.125rem",
      "$description": "Underline variant indicator.",
      "$extensions": {
        "looloo.tailwind": "h-0.5"
      }
    },
    "color": {
      "list-background": {
        "$type": "color",
        "$value": "{color.muted}",
        "$extensions": {
          "looloo.tailwind": "bg-muted"
        }
      },
      "trigger-foreground": {
        "$type": "color",
        "$value": "{color.muted-foreground}",
        "$extensions": {
          "looloo.tailwind": "text-muted-foreground"
        }
      },
      "trigger-active-background": {
        "$type": "color",
        "$value": "{color.background}",
        "$extensions": {
          "looloo.tailwind": "data-[state=active]:bg-background"
        }
      },
      "trigger-active-foreground": {
        "$type": "color",
        "$value": "{color.foreground}",
        "$extensions": {
          "looloo.tailwind": "data-[state=active]:text-foreground"
        }
      },
      "indicator-color": {
        "$type": "color",
        "$value": "{color.foreground}",
        "$description": "The underline variant's active bar.",
        "$extensions": {
          "looloo.tailwind": "bg-foreground"
        }
      },
      "focus-border": {
        "$type": "color",
        "$value": "{color.ring}",
        "$extensions": {
          "looloo.tailwind": "focus-visible:border-ring"
        }
      },
      "focus-ring": {
        "$type": "color",
        "$value": "{color.ring}",
        "$extensions": {
          "looloo.tailwind": "focus-visible:ring-ring/50"
        }
      },
      "focus-ring-opacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "ring-ring/50"
        }
      }
    }
  }
}
