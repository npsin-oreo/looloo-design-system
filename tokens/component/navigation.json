{
  "$description": "DRAFT — captured from components/ui/navigation-menu.tsx. Not consumed at runtime yet (Phase 4).",
  "navigation": {
    "trigger": {
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.2-5}",
        "$extensions": {
          "looloo.tailwind": "px-2.5"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "py-1.5"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.lg}",
        "$extensions": {
          "looloo.tailwind": "rounded-lg",
          "looloo.legacy": "0.625rem"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      },
      "chevronSize": {
        "$type": "dimension",
        "$value": "{size.12}",
        "$description": "size-3 (12px) — SMALLER than the 16px icon default. It is punctuation, not content: it says a panel opens here, and it rotates 180° when it does.",
        "$extensions": {
          "looloo.tailwind": "size-3"
        }
      },
      "chevronGap": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "ml-1"
        }
      }
    },
    "content": {
      "padding": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "p-2"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.lg}",
        "$extensions": {
          "looloo.tailwind": "rounded-lg",
          "looloo.legacy": "0.625rem"
        }
      },
      "shadow": {
        "$type": "shadow",
        "$value": "{shadow.md}",
        "$extensions": {
          "looloo.tailwind": "shadow-md"
        }
      }
    },
    "iconSize": {
      "$type": "dimension",
      "$value": "{size.16}",
      "$extensions": {
        "looloo.tailwind": "size-4",
        "looloo.legacy": "1rem"
      }
    },
    "color": {
      "trigger-hover-background": {
        "$type": "color",
        "$value": "{color.muted}",
        "$extensions": {
          "looloo.tailwind": "hover:bg-muted"
        }
      },
      "trigger-open-background": {
        "$type": "color",
        "$value": "{color.muted}",
        "$extensions": {
          "looloo.tailwind": "data-[state=open]:bg-muted/50"
        }
      },
      "trigger-open-opacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "data-[state=open]:bg-muted/50"
        }
      },
      "content-background": {
        "$type": "color",
        "$value": "{color.popover}",
        "$extensions": {
          "looloo.tailwind": "bg-popover"
        }
      },
      "content-foreground": {
        "$type": "color",
        "$value": "{color.popover-foreground}",
        "$extensions": {
          "looloo.tailwind": "text-popover-foreground"
        }
      },
      "content-ring": {
        "$type": "color",
        "$value": "{color.foreground}",
        "$extensions": {
          "looloo.tailwind": "ring-foreground/10"
        }
      },
      "content-ring-opacity": {
        "$type": "number",
        "$value": "{opacity.10}",
        "$extensions": {
          "looloo.tailwind": "ring-foreground/10"
        }
      },
      "indicator-color": {
        "$type": "color",
        "$value": "{color.border}",
        "$extensions": {
          "looloo.tailwind": "bg-border"
        }
      },
      "focus-ring": {
        "$type": "color",
        "$value": "{color.ring}",
        "$extensions": {
          "looloo.tailwind": "focus-visible:ring-ring/50"
        }
      },
      "focus-ring-opacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "ring-ring/50"
        }
      },
      "link-hover-background": {
        "$type": "color",
        "$value": "{color.muted}",
        "$description": "A link in the panel on hover/focus — the same muted wash the trigger uses, so the panel feels like part of the same surface.",
        "$extensions": {
          "looloo.tailwind": "hover:bg-muted focus:bg-muted"
        }
      }
    },
    "link": {
      "padding": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "p-2"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "gap-2"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "calc(var(--navigation-content-radius) - var(--navigation-content-padding))",
        "$description": "CONCENTRIC: --navigation-content-radius (10) − --navigation-content-padding (8) = 2px. A nested corner must be the outer radius MINUS the padding, or the gap at the corner stops matching the gap along the edge and the inner box looks pinched. Derived, not picked off the scale.",
        "$extensions": {
          "looloo.tailwind": "rounded-(--navigation-link-radius)",
          "looloo.previous": "{radius.ui.lg}"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      }
    },
    "viewport": {
      "marginTop": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$description": "Gap between the bar and the panel that drops from it (mt-1.5). Small on purpose: the panel belongs to the trigger above it, and a bigger gap would cut it loose.",
        "$extensions": {
          "looloo.tailwind": "mt-1.5"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.lg}",
        "$extensions": {
          "looloo.tailwind": "rounded-lg"
        }
      }
    },
    "indicator": {
      "size": {
        "$type": "dimension",
        "$value": "{size.8}",
        "$description": "An 8×8 square rotated 45° — a diamond whose top half becomes the arrow. It is not a triangle shape; it is a square that only shows its corner.",
        "$extensions": {
          "looloo.tailwind": "size-2 rotate-45"
        }
      },
      "height": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$description": "Only 6px of the diamond is ever visible (h-1.5, overflow-hidden) — the rest is clipped. That is what makes it read as an arrow pointing at the open trigger rather than as a floating lozenge.",
        "$extensions": {
          "looloo.tailwind": "h-1.5 overflow-hidden"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.sm}",
        "$extensions": {
          "looloo.tailwind": "rounded-tl-sm"
        }
      }
    }
  }
}
