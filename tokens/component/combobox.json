{
  "$description": "Captured 1:1 from components/ui/combobox/combobox.tsx. The trigger is a min-height field (it wraps chips), so height is a min-height, not a fixed control height.",
  "combobox": {
    "trigger": {
      "minHeight": {
        "$type": "dimension",
        "$value": "{size.control.lg}",
        "$extensions": {
          "looloo.tailwind": "min-h-9"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.md}",
        "$extensions": {
          "looloo.tailwind": "rounded-md"
        }
      },
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.2-5}",
        "$description": "Tightens to px-1.5 when the trigger holds chips.",
        "$extensions": {
          "looloo.tailwind": "px-2.5"
        }
      },
      "chipPaddingX": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$description": "Trigger padding when it holds chips (single-cap key: the kebab pass only splits at one capital, so paddingXChips would emit --…-padding-xchips).",
        "$extensions": {
          "looloo.tailwind": "has-data-[slot=combobox-chip]:px-1.5"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "py-1.5"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "gap-1.5"
        }
      },
      "borderWidth": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$extensions": {
          "looloo.tailwind": "border"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      },
      "shadow": {
        "$type": "shadow",
        "$value": "{shadow.xs}",
        "$extensions": {
          "looloo.tailwind": "shadow-xs"
        }
      },
      "focusRingWidth": {
        "$type": "dimension",
        "$value": "{focus.ring.width}",
        "$extensions": {
          "looloo.tailwind": "focus-within:ring-[3px]"
        }
      },
      "iconSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$description": "Grows to size-5 on coarse pointers.",
        "$extensions": {
          "looloo.tailwind": "size-4 pointer-coarse:size-5",
          "looloo.legacy": "1rem"
        }
      },
      "iconInset": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "right-2"
        }
      }
    },
    "chip": {
      "height": {
        "$type": "dimension",
        "$value": "{size.22}",
        "$description": "h-[calc(--spacing(5.5))] = 22px — literal in source, no space token at 5.5.",
        "$extensions": {
          "looloo.tailwind": "h-[calc(--spacing(5.5))]",
          "looloo.legacy": "1.375rem"
        }
      },
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "px-1.5"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "gap-1"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.sm}",
        "$extensions": {
          "looloo.tailwind": "rounded-sm"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "fontWeight": {
        "$type": "fontWeight",
        "$value": "{font.weight.medium}",
        "$extensions": {
          "looloo.tailwind": "font-medium"
        }
      },
      "background": {
        "$type": "color",
        "$value": "{color.muted}",
        "$extensions": {
          "looloo.tailwind": "bg-muted"
        }
      },
      "disabledOpacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "has-disabled:opacity-50"
        }
      },
      "removeOpacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$description": "The X on a chip is half-strength until hovered: it must be reachable, but it should not turn every chip into a row of delete buttons.",
        "$extensions": {
          "looloo.tailwind": "opacity-50 hover:opacity-100"
        }
      }
    },
    "content": {
      "maxHeight": {
        "$type": "dimension",
        "$value": "{space.96}",
        "$extensions": {
          "looloo.tailwind": "max-h-96"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{radius.ui.md}",
        "$extensions": {
          "looloo.tailwind": "rounded-md"
        }
      },
      "ringWidth": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$extensions": {
          "looloo.tailwind": "ring-1"
        }
      },
      "shadow": {
        "$type": "shadow",
        "$value": "{shadow.md}",
        "$extensions": {
          "looloo.tailwind": "shadow-md"
        }
      },
      "background": {
        "$type": "color",
        "$value": "{color.popover}",
        "$extensions": {
          "looloo.tailwind": "bg-popover"
        }
      },
      "foreground": {
        "$type": "color",
        "$value": "{color.popover-foreground}",
        "$extensions": {
          "looloo.tailwind": "text-popover-foreground"
        }
      }
    },
    "list": {
      "padding": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "p-1"
        }
      }
    },
    "item": {
      "radius": {
        "$type": "dimension",
        "$value": "calc(var(--combobox-content-radius) - var(--combobox-list-padding))",
        "$description": "CONCENTRIC: --combobox-content-radius − --combobox-list-padding = 4px. A nested corner must be the outer radius MINUS the padding, or the gap at the corner is not the gap along the edge — the inner box looks either pinched or rattling around inside its container. Was picked off the radius scale by eye; now it is derived.",
        "$extensions": {
          "looloo.tailwind": "rounded-(--combobox-content-item-radius)",
          "looloo.previous": "{radius.ui.sm}"
        }
      },
      "paddingLeft": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "pl-2"
        }
      },
      "paddingRight": {
        "$type": "dimension",
        "$value": "{space.8}",
        "$description": "Room for the trailing check indicator.",
        "$extensions": {
          "looloo.tailwind": "pr-8"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "py-1.5"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "gap-2"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      },
      "iconSize": {
        "$type": "dimension",
        "$value": "{size.16}",
        "$extensions": {
          "looloo.tailwind": "[&_svg]:size-4",
          "looloo.legacy": "1rem"
        }
      },
      "disabledOpacity": {
        "$type": "number",
        "$value": "{opacity.50}",
        "$extensions": {
          "looloo.tailwind": "data-[disabled]:opacity-50"
        }
      },
      "highlightedBackground": {
        "$type": "color",
        "$value": "{color.accent}",
        "$extensions": {
          "looloo.tailwind": "data-highlighted:bg-accent"
        }
      },
      "highlightedForeground": {
        "$type": "color",
        "$value": "{color.accent-foreground}",
        "$extensions": {
          "looloo.tailwind": "data-highlighted:text-accent-foreground"
        }
      }
    },
    "label": {
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "px-2"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "py-1.5"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.xs}",
        "$extensions": {
          "looloo.tailwind": "text-xs"
        }
      },
      "foreground": {
        "$type": "color",
        "$value": "{color.muted-foreground}",
        "$extensions": {
          "looloo.tailwind": "text-muted-foreground"
        }
      }
    },
    "empty": {
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.2}",
        "$extensions": {
          "looloo.tailwind": "py-2"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{font.size.sm}",
        "$extensions": {
          "looloo.tailwind": "text-sm"
        }
      },
      "foreground": {
        "$type": "color",
        "$value": "{color.muted-foreground}",
        "$extensions": {
          "looloo.tailwind": "text-muted-foreground"
        }
      }
    },
    "separator": {
      "marginY": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$extensions": {
          "looloo.tailwind": "my-1"
        }
      },
      "bleedX": {
        "$type": "dimension",
        "$value": "{space.1}",
        "$description": "Applied as a NEGATIVE margin (-mx-1).",
        "$extensions": {
          "looloo.tailwind": "-mx-1"
        }
      },
      "thickness": {
        "$type": "dimension",
        "$value": "{border.width.default}",
        "$extensions": {
          "looloo.tailwind": "h-px"
        }
      }
    },
    "chips": {
      "minHeight": {
        "$type": "dimension",
        "$value": "{size.control.lg}",
        "$description": "The chips box IS the trigger in a multi-select (min-h-9). A min-height, not a height: the box grows as chips wrap onto new lines.",
        "$extensions": {
          "looloo.tailwind": "min-h-9"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$description": "Between chips, and between the last chip and the typing area.",
        "$extensions": {
          "looloo.tailwind": "gap-1.5"
        }
      },
      "paddingX": {
        "$type": "dimension",
        "$value": "{space.2-5}",
        "$extensions": {
          "looloo.tailwind": "px-2.5"
        }
      },
      "paddingY": {
        "$type": "dimension",
        "$value": "{space.1-5}",
        "$extensions": {
          "looloo.tailwind": "py-1.5"
        }
      }
    },
    "chipsInput": {
      "minWidth": {
        "$type": "dimension",
        "$value": "{space.16}",
        "$description": "The typing area that trails the chips. It keeps a 64px floor so there is always somewhere to type — without it, enough chips would squeeze the caret out of the box entirely.",
        "$extensions": {
          "looloo.tailwind": "min-w-16 flex-1"
        }
      }
    }
  }
}
