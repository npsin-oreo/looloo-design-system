{
  "$description": "Captured from components/ui/select/select.tsx — WIRED: the cva/class strings consume the generated --select-* vars.",
  "select": {
    "trigger": {
      "height": {
        "sm": { "$type": "dimension", "$value": "{size.control.sm}", "$extensions": { "looloo.tailwind": "h-7 (data-[size=sm])" } },
        "md": { "$type": "dimension", "$value": "{size.control.md}", "$description": "DEFAULT size.", "$extensions": { "looloo.tailwind": "h-8" } },
        "xl": { "$type": "dimension", "$value": "{size.control.xl}", "$extensions": { "looloo.tailwind": "h-10 (data-[size=xl])" } }
      },
      "radius": { "$type": "dimension", "$value": "0.625rem", "$extensions": { "looloo.tailwind": "rounded-lg" } },
      "gap": { "$type": "dimension", "$value": "{space.1-5}", "$extensions": { "looloo.tailwind": "gap-1.5" } },
      "fontSize": { "$type": "dimension", "$value": "{font.size.sm}", "$extensions": { "looloo.tailwind": "text-sm" } }
    },
    "content": {
      "radius": { "$type": "dimension", "$value": "0.625rem", "$description": "Corrected in Phase 4: source uses rounded-lg (the Phase-1 draft said rounded-md).", "$extensions": { "looloo.tailwind": "rounded-lg" } },
      "padding": { "$type": "dimension", "$value": "{space.1}", "$description": "Viewport padding (p-1).", "$extensions": { "looloo.tailwind": "p-1" } },
      "shadow": { "$type": "shadow", "$value": "{shadow.md}", "$extensions": { "looloo.tailwind": "shadow-md" } }
    },
    "iconSize": { "$type": "dimension", "$value": "1rem", "$extensions": { "looloo.tailwind": "size-4" } }
  }
}
