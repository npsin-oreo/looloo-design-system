{
  "$description": "Theme-tier overlay for \"neutral\" — the brand's tunable scalars (radius base, fonts, motion, layout, type axes). Generated from brand.config.json by scripts/tokens/build-theme.mjs (Phase 4). Semantic/primitive tiers stay brand-agnostic; this overlay carries the brand values.",
  "theme": {
    "neutral": {
      "radius": {
        "$type": "dimension",
        "$value": "0.75rem",
        "$description": "Base --radius; runtime scale is calc-based in app/globals.css."
      },
      "font": {
        "sans": {
          "$type": "fontFamily",
          "$value": "Noto Sans Thai"
        },
        "mono": {
          "$type": "fontFamily",
          "$value": "Geist Mono"
        }
      },
      "motion": {
        "duration": {
          "$type": "duration",
          "$value": "200ms"
        },
        "ease": {
          "$type": "cubicBezier",
          "$value": "cubic-bezier(0.4, 0, 0.2, 1)"
        }
      },
      "layout": {
        "container": {
          "$type": "dimension",
          "$value": "1280px"
        },
        "section": {
          "$type": "dimension",
          "$value": "6rem"
        }
      },
      "typography": {
        "leading": {
          "$type": "number",
          "$value": "1.5",
          "$description": "Body line-height (brand.css re-points --text-base--line-height)."
        },
        "tracking": {
          "$type": "dimension",
          "$value": "0em",
          "$description": "Letter-spacing (brand.css re-points --tracking-tight)."
        },
        "weightHeading": {
          "$type": "fontWeight",
          "$value": "600",
          "$description": "Heading weight (--weight-heading)."
        }
      }
    }
  }
}
