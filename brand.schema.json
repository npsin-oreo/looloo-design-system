{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/npsin-oreo/looloo-design-system/brand.schema.json",
  "title": "Brand config",
  "description": "Per-brand theme overlay for the white-label base. Edit brand.config.json (neutral) or brands/<name>.config.json, then run `npm run tokens:theme && npm run tokens:build` (auto-runs on dev/build). See THEMING.md. Two accepted shapes: the nested DS shape ({name, light:{...}, dark:{...}}) and the flat consumer-theming shape the DesignOps pipeline emits ({project_name, primary, background, ...}).",
  "type": "object",
  "anyOf": [
    { "required": ["name", "light"] },
    { "required": ["project_name"] }
  ],
  "additionalProperties": { "$ref": "#/$defs/color" },
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "description": "Brand name — shown in the showcase header and the generated brand.css."
    },
    "project_name": {
      "type": "string",
      "description": "Flat-shape alias for `name` (DesignOps Step 2.6 output)."
    },
    "description": { "type": "string" },
    "radius": {
      "type": "string",
      "description": "Default corner radius (--radius), e.g. \"0.5rem\".",
      "default": "0.5rem"
    },
    "font_sans": {
      "type": "string",
      "description": "Flat-shape alias for `fonts.sans`."
    },
    "font_mono": {
      "type": "string",
      "description": "Flat-shape alias for `fonts.mono`."
    },
    "fonts": {
      "type": "object",
      "description": "Font metadata (documentation only — fonts are wired in app/layout.tsx + app/fonts/).",
      "additionalProperties": false,
      "properties": {
        "sans": { "type": "string" },
        "mono": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "light": {
      "$ref": "#/$defs/tokenSet",
      "description": "Light-mode tokens (:root). At minimum set `primary`."
    },
    "dark": {
      "$ref": "#/$defs/tokenSet",
      "description": "Dark-mode tokens (.dark)."
    },
    "axes": {
      "$ref": "#/$defs/axisSet",
      "description": "Non-colour design axes (typography/motion/layout) — themeable scalars beyond colour + radius/font. All optional; an omitted axis inherits the white-label default."
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "description": "A CSS color — hex (#rgb/#rrggbb), a functional notation like rgb()/hsl()/oklch(), or a named color.",
      "pattern": "^(#[0-9a-fA-F]{3,8}|[a-zA-Z-]+\\([^)]*\\)|[a-zA-Z]+)$"
    },
    "tokenSet": {
      "type": "object",
      "additionalProperties": false,
      "description": "Semantic color tokens. Any omitted *-foreground is auto-derived by luminance.",
      "properties": {
        "background": { "$ref": "#/$defs/color" },
        "foreground": { "$ref": "#/$defs/color" },
        "card": { "$ref": "#/$defs/color" },
        "card-foreground": { "$ref": "#/$defs/color" },
        "popover": { "$ref": "#/$defs/color" },
        "popover-foreground": { "$ref": "#/$defs/color" },
        "primary": { "$ref": "#/$defs/color" },
        "primary-foreground": { "$ref": "#/$defs/color" },
        "secondary": { "$ref": "#/$defs/color" },
        "secondary-foreground": { "$ref": "#/$defs/color" },
        "muted": { "$ref": "#/$defs/color" },
        "muted-foreground": { "$ref": "#/$defs/color" },
        "accent": { "$ref": "#/$defs/color" },
        "accent-foreground": { "$ref": "#/$defs/color" },
        "destructive": { "$ref": "#/$defs/color" },
        "border": { "$ref": "#/$defs/color" },
        "input": { "$ref": "#/$defs/color" },
        "ring": { "$ref": "#/$defs/color" },
        "chart-1": { "$ref": "#/$defs/color" },
        "chart-2": { "$ref": "#/$defs/color" },
        "chart-3": { "$ref": "#/$defs/color" },
        "chart-4": { "$ref": "#/$defs/color" },
        "chart-5": { "$ref": "#/$defs/color" },
        "sidebar": { "$ref": "#/$defs/color" },
        "sidebar-foreground": { "$ref": "#/$defs/color" },
        "sidebar-primary": { "$ref": "#/$defs/color" },
        "sidebar-primary-foreground": { "$ref": "#/$defs/color" },
        "sidebar-accent": { "$ref": "#/$defs/color" },
        "sidebar-accent-foreground": { "$ref": "#/$defs/color" },
        "sidebar-border": { "$ref": "#/$defs/color" },
        "sidebar-ring": { "$ref": "#/$defs/color" },
        "background-color": { "$ref": "#/$defs/color" },
        "semantic-background": { "$ref": "#/$defs/color" },
        "semantic-foreground": { "$ref": "#/$defs/color" },
        "semantic-border": { "$ref": "#/$defs/color" }
      }
    },
    "axisSet": {
      "type": "object",
      "additionalProperties": false,
      "description": "Non-colour axis tokens. All optional; an omitted axis inherits the white-label default.",
      "properties": {
        "ease": { "type": "string", "description": "Brand easing curve → --ease-brand (apply via [data-slot] / ease-[var(--ease-brand)])." },
        "duration": { "type": "string", "description": "Base transition duration → --duration-base." },
        "leading": { "type": "string", "description": "Base line-height → @theme --text-base--line-height (utilities inherit)." },
        "tracking": { "type": "string", "description": "Display letter-spacing → @theme --tracking-tight." },
        "weight_heading": { "type": "string", "description": "Heading font-weight cap → --weight-heading." },
        "container": { "type": "string", "description": "Max content width → --container-max." },
        "section": { "type": "string", "description": "Section vertical rhythm → --space-section." }
      }
    }
  }
}
