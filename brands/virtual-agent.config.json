  "fonts": {
    "sans": "Noto Sans Thai",
    "mono": "Geist Mono",
    "note": "sans ships via next/font/google (Thai + Latin subsets) in app/layout.tsx; mono is a local file in app/fonts/ (swap both there per brand)."
