{
  "name": "@npsin-oreo/design-system",
  "version": "2.0.0",
  "private": false,
  "files": [
    "app/globals.css",
    "app/shadcn.css",
    "dist",
    "components/theme-provider.tsx",
    "components/ui",
    "brands",
    "hooks",
    "lib",
    "scripts/lib-oklch.mjs",
    "brand.schema.json",
    "THEMING.md",
    "CHANGELOG.md"
  ],
  "exports": {
    "./styles.css": "./app/globals.css",
    "./theme-provider": "./components/theme-provider.tsx",
    "./*": "./components/ui/*.tsx",
    "./brand.schema.json": "./brand.schema.json",
    "./brands/virtual-agent/logo-artwork": "./brands/virtual-agent/logo-artwork.tsx"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "predev": "npm run tokens:build",
    "dev": "next dev",
    "prebuild": "npm run tokens:build",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run tokens:validate && npm run tokens:build && npm run audit:styles -- --strict && npm run audit:icons -- --strict && npm run tokens:audit -- --strict",
    "tokens:import": "node scripts/import-figma-tokens.mjs",
    "tokens:theme": "node scripts/tokens/build-theme.mjs",
    "tokens:css-check": "node scripts/tokens/check-css-snapshot.mjs",
    "tokens:validate": "node scripts/tokens/validate.mjs",
    "tokens:build": "node scripts/tokens/build-css.mjs && node scripts/tokens/build-ts.mjs && node scripts/tokens/build-contract.mjs",
    "tokens:audit": "node scripts/tokens/audit-contrast.mjs",
    "audit:styles": "node scripts/audit/hardcoded-styles.mjs",
    "audit:components": "node scripts/audit/component-token-coverage.mjs",
    "audit:icons": "node scripts/audit/icon-usage.mjs",
    "icons:contract": "node scripts/registry/build-icon-contract.mjs",
    "contracts:build": "node scripts/registry/build-contracts.mjs",
    "prepublishOnly": "npm run tokens:build",
    "storybook": "npm run tokens:build && storybook dev -p 6006",
    "build-storybook": "npm run tokens:build && storybook build",
    "test-storybook": "npm run tokens:build && vitest run --project=storybook"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.78.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tw-animate-css": "^1.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-themes": "^10.4.4",
    "@storybook/addon-vitest": "^10.4.4",
    "@storybook/nextjs-vite": "^10.4.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "next": "^15.0.0",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.11.0",
    "storybook": "^10.4.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/npsin-oreo/looloo-design-system.git"
  }
}
